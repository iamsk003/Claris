# CLARIS environment — copy to .env and fill in. NEVER commit .env.
# Inference is Fireworks AI only (plus optional local vLLM). No OpenRouter/Groq/etc.

# --- Fireworks AI (required) -------------------------------------------------
FIREWORKS_API_KEY=fw_your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Gemma model IDs the AGENT requires (no defaults — a missing one is a fatal startup
# error, and a wrong one is caught by the 1-token preflight). Set all four.
GEMMA_VLM_MODEL=accounts/fireworks/models/gemma-3-vlm
GEMMA_GEN_MODEL=accounts/fireworks/models/gemma-3
GEMMA_GATE1_MODEL=accounts/fireworks/models/gemma-3
GEMMA_CRITIC_MODEL=accounts/fireworks/models/gemma-3

# Non-Gemma fallback. Used ONLY as a logged degradation (sets degraded=True).
CLARIS_FALLBACK_MODEL=

# --- Optional local vLLM GPU backend -----------------------------------------
# Leave blank to disable. When set, this is the most-preferred provider tier.
CLARIS_LOCAL_VLLM_BASE_URL=
CLARIS_LORA_ADAPTER_PATH=

# --- Pipeline knobs ----------------------------------------------------------
CLARIS_SAMPLES_PER_STYLE=4
CLARIS_TONE_SIMILARITY_THRESHOLD=0.82
CLARIS_SEED=1337
CLARIS_CACHE_DIR=.claris_cache
CLARIS_LOG_DIR=.claris_logs

# --- Timeouts (seconds) — nothing runs unbounded -----------------------------
CLARIS_FFMPEG_TIMEOUT_S=60
CLARIS_LLM_TIMEOUT_S=90
CLARIS_TASK_TIMEOUT_S=600
